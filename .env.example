# LexGuard Environment Variables
# Copy this file to .env and fill in your API keys

# Groq API Key (get one at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
# Optional: model to use on Groq (default: llama-3.1-8b-instant)
GROQ_MODEL=llama-3.1-8b-instant

# Comma-separated CORS origins for local dev and Cloud Run
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://YOUR_CLOUD_RUN_URL
